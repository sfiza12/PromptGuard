# ============================================================
# PromptGuard Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains real secrets!
# ============================================================

# --- Required ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Django Security ---
# Generate a secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Downstream LLM API Keys (server-side only) ---
# These keys are NEVER accepted from client requests.
# Set the keys for the LLMs you want to use via the firewall.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GEMINI_API_KEY is already set above — it's used for both
# the firewall analyzer AND the Gemini LLM adapter.

# --- Rate Limiting ---
# Max API requests per IP per minute (default: 30)
RATE_LIMIT_PER_MINUTE=30

# --- Output Response Scanning ---
# Scan LLM responses before returning them to the user.
# Set to False to disable (default: True)
OUTPUT_SCANNING_ENABLED=True

# --- Webhook Alerting ---
# URL to POST alerts when a prompt is BLOCKED with high risk score.
# Supports Slack incoming webhooks, PagerDuty, or any HTTP endpoint.
# Leave empty to disable.
PROMPTGUARD_WEBHOOK_URL=
# Minimum risk score to trigger webhook (default: 80)
PROMPTGUARD_WEBHOOK_THRESHOLD=80
